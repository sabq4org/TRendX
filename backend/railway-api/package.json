{
  "name": "trendx-railway-api",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "migrate": "prisma migrate deploy",
    "seed": "node dist/seed.js",
    "seed:dev": "tsx src/seed.ts",
    "postdeploy": "node dist/bootstrap-db.js && prisma migrate deploy && node dist/seed.js",
    "studio": "prisma studio",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@hono/node-server": "^1.13.0",
    "@prisma/client": "5.22.0",
    "hono": "^4.6.0",
    "pg": "^8.13.0",
    "prisma": "5.22.0"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "@types/pg": "^8.11.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  }
}
