# Copy to `.env.local` and fill in real values.
# `.env.local` is gitignored — never commit secrets.

# Base URL of the Railway API the dashboard talks to. Leave unset to use
# the production Railway URL hard-coded in `lib/api.ts`.
NEXT_PUBLIC_TRENDX_API="https://trendx-production.up.railway.app"

# Vercel Blob read+write token. Required for the cover-image uploader
# at `/api/upload`. Generate one in the Vercel project under
# Storage → Blob → "Connect Project". Never share or commit the value.
BLOB_READ_WRITE_TOKEN=""
